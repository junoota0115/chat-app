<div class="chat-header">
 <div class="chat-room-name">fogehuga
 </div>
  <div class="chat-exit">
  <a href="#仮置き">チャットを終了する</a>
 </div>
</div>

<div class="messages">

 <div class="message">
 </div>

 <div class="message">
  <div class="up-users">
   <div class="up-name">Tom</div>
   <div class="up-day">2021/04/21/(木)/16:07</div>
  </div>
   <div class="message-text">おはよう</div>
 </div>
</div>


<%= form_with model: [@room, @message], class: 'form', local: true do |f| %>
  <div class="form-input">
    <%= f.text_field :content, class: 'form-message', placeholder: 'type a message' %>
    <label class="form-image">
      <span class="image-file">画像</span>
      <%= f.file_field :image, class: 'hidden' %>
    </label>
  </div>
  <%= f.submit '送信', class: 'form-submit' %>
<% end %>